# API service — mount a volume at /app/data for persistent SQLite (noscroll.db).
FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

RUN mkdir -p data

ENV PYTHONUNBUFFERED=1
# Demo deploy: seed friends + shared demo user (override in Railway)
ENV SEED_FRIENDS_ON_STARTUP=true
ENV DEMO_USER_TOKEN=a1b2c3d4-e5f6-4789-a012-3456789abcde

EXPOSE 8000

CMD ["sh", "-c", "python -m uvicorn main:app --host 0.0.0.0 --port ${PORT:-8000}"]
